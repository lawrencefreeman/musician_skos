    mus:hasMember mus:JohnnyAllenHendrix ;
    mus:inBrand mus:JimmiHendrix .

mus:JimmiHendrix rdf:type mus:artistBrand ;
    mus:artistConfiguration mus:solo ;
    mus:performedAt mus:woodStock ;
    mus:isKnownForSong mus:littleWing ;
    mus:playedIn mus:littleWing ;

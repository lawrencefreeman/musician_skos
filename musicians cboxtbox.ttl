    mus:hasMember mus:CalvinCordozarBroadusJr ;
    mus:inBrand mus:SnoopDog .

mus:SnoopDog rdf:type mus:artistBrand ;
    mus:artistConfiguration mus:solo ;
    mus:performedAt mus:trumpInaugurationWeekend ;
    mus:isKnownForSong mus:dropItLikeItsHot ;
    mus:playedIn mus:dropItLikeItsHot ;
    mus:isKnownForAlbum mus:theDogFather ;

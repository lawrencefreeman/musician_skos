@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Ontology for musicians
@prefix mus:  <https://eu.cohort1.kgg.org/music/musicians_ontology#> .

# Controlled Vocabulary (SKOS) for musicians
@prefix muv: <https://eu.cohort1.kgg.org/music/musicians_vocabulary#> .


###################################
# Initial joined Work             #
###################################


# --- Ontology Declaration ---
mus:musicOntology rdf:type owl:Ontology ;
    rdfs:label "The Musicians Ontology"@en ;
    rdfs:comment "An ontology for modelling musicians, their roles, instruments, genres, and musical works."@en .


# Class Artist
mus:Artist rdf:type owl:Class ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Artist"@en ;
    rdfs:comment "A person or group that creates, performs, or contributes to musical works."@en .

# DatatypeProperty age
mus:age rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Artist ;
    rdfs:range xsd:integer ;
    rdfs:label "Age"@en ;
    rdfs:comment "The age of the artist in years."@en .



###################################
# AYALETS WORK #
###################################

mus:ArtistBrand rdf:type owl:Class ;
mus:ArtistConfiguration rdf:type owl:Class ;



###################################
# JEFFS WORK                      #
###################################

# Peak Decade of the artist
mus:heyday rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Artist ;
    rdfs:range xsd:gYear ;
    rdfs:label "Heyday"@en ;
    rdfs:comment "The peak decade of the artist's career, represented as the starting year of the decade (e.g., 1980 for the 1980s)."@en .

# Generic Membership class
mus:Membership rdf:type owl:Class ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Membership"@en ;
    rdfs:comment "A more generic relation representing the participation of an Artist in an ArtistBrand during a specific time period. Used for e.g. the role(s) fulfilled."@en .

mus:Role rdf:type owl:Class ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Role"@en ;
    rdfs:comment "The function an artist fulfils within an ArtistBrand, e.g., instrumentalist, vocalist, conductor, composer."@en .


# ---------------------------------------------------------------------------------
# Relation Artist to Artist Brand using Membership
# ---------------------------------------------------------------------------------

# a Membership has a Member which is the artist
mus:hasMember rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Membership ;
    rdfs:range mus:Artist ;
    rdfs:label "has member"@en ;
    rdfs:comment "Links a Membership to the Artist (person) who participates."@en .

mus:inBrand rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Membership ;
    rdfs:range mus:ArtistBrand ;
    rdfs:label "in brand"@en ;
    rdfs:comment "Links a Membership to the ArtistBrand in which the artist participates."@en .

mus:hasRole rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Membership ;
    rdfs:range mus:Role ;
    rdfs:label "has role"@en ;
    rdfs:comment "Links a Membership to the Role the artist fulfils in that brand."@en .


# Membership datatype properties

mus:startDate rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Membership ;
    rdfs:range xsd:date ;
    rdfs:label "start date"@en ;
    rdfs:comment "The date on which the membership began."@en .

mus:endDate rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Membership ;
    rdfs:range xsd:date ;
    rdfs:label "end date"@en ;
    rdfs:comment "The date on which the membership ended. Absent if still active."@en .


# ---------------------------------------------------------------------------------
# C-Box: Roles from SKOS added to Ontology
#        Using owl:sameAs 
#
#  Is this the right approach to incorporate SKOS?
#
# ---------------------------------------------------------------------------------

mus:Instrumentalist
    owl:sameAs muv:instrumentalist ;
    rdfs:comment "A musician who plays a musical instrument."@en .

mus:Vocalist
    owl:sameAs muv:vocalist ;
    rdfs:comment "A person who sings, using the human voice as the primary instrument."@en .

mus:Composer
    owl:sameAs muv:composer ;
    rdfs:comment "A person who creates musical compositions."@en .

mus:Conductor
    owl:sameAs muv:conductor ;
    rdfs:comment "A person who directs a musical ensemble through gestures and interpretation."@en .


# -----------------------------------------------------------------------------
# ObjectProperty: subRoleOf
#     Mirrors skos:broader within the ontology's own vocabulary.
#     Declared as transitive 'owl:TransitiveProperty'
#     so that e.g. AcousticGuitarist subRoleOf Guitarist.
#     subRoleOf Instrumentalist can be inferred as AcousticGuitarist subRoleOf
#
#  Is this the right approach to incorporate SKOS?
#  Or shall we build sub classes?
#
# -----------------------------------------------------------------------------

mus:subRoleOf rdf:type owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:domain mus:Role ;
    rdfs:range  mus:Role ;
    rdfs:label "sub-role of"@en ;
    rdfs:comment "Indicates that this role is a specialization of a broader role. Transitive: if A subRoleOf B and B subRoleOf C, then A subRoleOf C is inferred."@en .



# ---------------------------------------------------------------------------------
# L2/L3 – Instrumentalist branch
# ---------------------------------------------------------------------------------

#  L2: Guitarist --
mus:Guitarist rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Guitarist"@en ;
    rdfs:comment "A musician who plays the guitar."@en ;
    mus:subRoleOf mus:Instrumentalist ;
    owl:sameAs muv:guitarist .

#  L3: Acoustic Guitarist --
mus:AcousticGuitarist rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Acoustic Guitarist"@en ;
    rdfs:comment "A guitarist who primarily performs on a non-amplified, steel-string or nylon-string acoustic guitar."@en ;
    mus:subRoleOf mus:Guitarist ;
    owl:sameAs muv:acoustic_guitarist .

#  L3: Electric Guitarist --
mus:ElectricGuitarist rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Electric Guitarist"@en ;
    rdfs:comment "A guitarist who primarily performs on an electrically amplified guitar using pickups and an amplifier."@en ;
    mus:subRoleOf mus:Guitarist ;
    owl:sameAs muv:electric_guitarist .

#  L2: Pianist --
mus:Pianist rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Pianist"@en ;
    rdfs:comment "A musician who plays the piano or keyboard instruments."@en ;
    mus:subRoleOf mus:Instrumentalist ;
    owl:sameAs muv:pianist .

#  L2: Drummer --
mus:Drummer rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Drummer"@en ;
    rdfs:comment "A musician who plays drums or percussion instruments, typically a drum kit."@en ;
    mus:subRoleOf mus:Instrumentalist ;
    owl:sameAs muv:drummer .

#  L2: Bassist --
mus:Bassist rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Bassist"@en ;
    rdfs:comment "A musician who plays a bass instrument, providing the low-pitched rhythmic and harmonic foundation."@en ;
    mus:subRoleOf mus:Instrumentalist ;
    owl:sameAs muv:bassist .

#  L3: Electric Bassist --
mus:ElectricBassist rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Electric Bassist"@en ;
    rdfs:comment "A bassist who performs on an electric bass guitar."@en ;
    mus:subRoleOf mus:Bassist ;
    owl:sameAs muv:electric_bassist .

#  L3: Upright Bassist --
mus:UprightBassist rdf:type mus:Role ;
    rdfs:isDefinedBy mus:musicOntology ;
    rdfs:label "Upright Bassist"@en ;
    rdfs:comment "A bassist who performs on an acoustic upright (double) bass."@en ;
    mus:subRoleOf mus:Bassist ;
    owl:sameAs muv:upright_bassist .




# -----------------------------------------------------------------------------
# Include the SKOS specs (muv:) here also?!
#
#  Is this the right approach to incorporate SKOS?
#
# -----------------------------------------------------------------------------

# just an example for instrumentalist ...

muv:instrumentalist rdf:type skos:Concept ;
    skos:inScheme muv:musician_role ;
    skos:prefLabel "Instrumentalist"@en ;
    skos:altLabel "Instrument player"@en ,
                  "Instrumental musician"@en ,
                  "Instrumental performer"@en ;
    skos:definition "A musician who plays a musical instrument."@en ;
    skos:exactMatch <https://www.wikidata.org/wiki/Q1278335> ;
    skos:scopeNote "Broad category covering all instrument families including strings, wind, percussion, keyboards, and electronic instruments."@en ;
    skos:topConceptOf muv:musician_role ;
    skos:narrower muv:guitarist ,
                  muv:pianist ,
                  muv:drummer ,
                  muv:bassist .








###################################
# LOZS WORK #
###################################







